{
  "name": "agenzo-cli-workspace",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "dev": "npm run dev --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:error-codes": "node scripts/check-error-codes.mjs"
  },
  "workspaces": [
    "packages/*",
    "apps/admin-cli",
    "apps/token-cli",
    "apps/merchant-cli",
    "apps/payment-cli"
  ],
  "devDependencies": {
    "@types/node": "^22.0.0",
    "fast-check": "^4.7.0",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0",
    "vitest": "^3.2.6"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
